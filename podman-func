#!/bin/bash

setup-priv-ports () {
    echo "net.ipv4.ip_unprivileged_port_start=80" > "/etc/sysctl.d/podman-privileged-ports.conf"
    sysctl --load /etc/sysctl.d/podman-privileged-ports.conf
}


install-podman () {
    # Check for podman install
    if [[ $(which podman) && $(podman --version) ]]; then
            echo "Podman is already installed, skipping..."
        else
            echo "Podman is not installed, installing..."
            apt install podman podman-compose podman-docker podman-remote podman-toolbox passt aardvark-dns systemd-container -y
            setup-priv-ports
    fi
}


create-podman-systemd () {
    SRV_FILE_CONFIG="/home/${DUSER}/.config"
    SRV_FILE_LOC="${SRV_FILE_CONFIG}/systemd/user"
    SRV_FILE="podman-compose.service"
    echo -e "\nGenerating ${SRV_FILE_LOC}/${SRV_FILE}"
    mkdir -p "${SRV_FILE_LOC}"
	tee "${SRV_FILE_LOC}/${SRV_FILE}" <<-EOF >/dev/null
		[Unit]
		Description=Podman via podman-compose
		Wants=network-online.target
		After=network-online.target
		RequiresMountsFor=%t/containers
		
		[Service]
		Environment=PODMAN_SYSTEMD_UNIT=%n
		Environment=PODMAN_USERNS=keep-id
		Restart=always
		TimeoutStartSec=60
		TimeoutStopSec=60
		ExecStart=/usr/bin/podman-compose up
		ExecStop=/usr/bin/podman-compose down
		Type=simple
		WorkingDirectory=%h
		
		[Install]
		WantedBy=default.target

	EOF

    # Fix user permissions for ${SRV_FILE_CONFIG}
    chown -fR ${DUSER}:${DUSER} ${SRV_FILE_CONFIG}
    chmod -fR 770 ${SRV_FILE_CONFIG}

    # Create the service
    machinectl shell --uid=${DUSER} .host $(which systemctl) --user daemon-reload
    machinectl shell --uid=${DUSER} .host $(which systemctl) --user enable podman-compose
}

setup-podman-user () {
    # Setup podman registries
    REGDIR_CONF="/home/${DUSER}/.config"
    REGDIR_LOC="${REGDIR_CONF}/containers"
    REG_FILE="registries.conf"
    mkdir -p "${REGDIR_LOC}"
    echo "unqualified-search-registries = [${PODMAN_REG}]" > "${REGDIR_LOC}/${REG_FILE}"

    # Fix user permissions ${REGDIR_CONF}
    chown -fR ${DUSER}:${DUSER} ${REGDIR_CONF}
    chmod -fR 770 ${REGDIR_CONF}

    # Enable podman socket for ${DUSER}
    machinectl shell --uid=${DUSER} .host $(which systemctl) --user enable --now podman.socket

    # Allow ${DUSER} to keep containers running after logout
    loginctl enable-linger ${DUSER}

    create-podman-systemd
}