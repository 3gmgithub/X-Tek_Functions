#!/bin/bash

check-answer () {
  if [ ${ANSWER,,} == "n" ]; then
    read -p "Did you update the script file variables file (C)ontinue/(N)o? " ANSWER
    if [ ${ANSWER,,} == "c" ]
    then
        echo "Ok continuing..."
    else
        echo "Stopping now..."
        exit 0
    fi
  fi
}

create-duser () {
    echo -e "\nCreating ${DUSER}"
    useradd -m ${DUSER} -s /bin/bash
    echo -n "${DUSER}:${DUSERPW}"|chpasswd

    PUID=$(id -u ${DUSER})
    PGID=$(id -g ${DUSER})

    # Check for podman install
    if [[ $(which podman) && $(podman --version) ]]; then
            echo "Podman is installed, skipping add user to docker group..."

        else
            # Add user to docker group to manage docker containers
            usermod -aG docker ${DUSER}
    fi


    # Enable BYOBU for ${DUSER}
    sudo -i -u ${DUSER} byobu-select-backend screen
    sudo -i -u ${DUSER} byobu-enable-prompt
    sudo -i -u ${DUSER} byobu-enable

    # Update .bashrc with ll command and color
    sed -i '/^#.*export GCC_COLORS/s/^#//' /home/${DUSER}/.bashrc

    # \x27 is a quote in hex
    sed -i 's,#alias ll=\x27ls -l\x27,alias ll=\x27ls -alh\x27,g' /home/${DUSER}/.bashrc
}

download-pfiles () {

    # Define usage of function
    dpf_usage () {
			tee <<-EOF
				Download private GITHUB files
				Usage: $0 [OPTIONS]
				    
				Options:
				    
				    --help            Display this help message
				    --git-owner       Put GIT owner here
				    --git-repo        Put GIT repo here
				    --git-path        Put GIT filepath here EX: src/main.py
				    --git-token       Put GIT token here
				    --download        Put download file and path EX: ./dest/main.py
				    
				Example:
				
				$0 --git-owner 'gitrepowner' --get-repo 'myrepo' --git-path 'src/main.py' --git-token 'github_pat_TOKEN' --download './dest/main.py'
			EOF
    }

    # Get CMD Options

    # *** Make sure you have a new enough getopt to handle long options (see the man page)
    getopt -T &>/dev/null
    if [[ $? -ne 4 ]]; then 
        echo "Getopt is too old!" >&2
        exit 1
    fi

    # Check if the number of arguments is 0
    if [ $# -eq 0 ]; then
        dpf_usage
        exit 0
    fi

    # Set Options (-a also accepts short options)
    OPTS=$(getopt -o '' -a --longoptions 'help,git-owner:,git-repo:,git-path:,git-token:,download:' -n "$0" -- "$@")
    eval set -- "$OPTS"

    if [ $? != 0 ] ; then
        echo "Failed parsing options." >&2
        exit
    fi

    while true; do
      case "$1" in
        --help)
            dpf_usage
            exit 0
            shift
            ;;
        --git-owner)
            GIT_OWNER=${2}
            shift 2
            ;;
        --git-repo)
            GIT_REPO=${2}
            shift 2
            ;;
        --git-path)
            GIT_PATH=${2}
            shift 2
            ;;
        --git-token)
            GIT_TOKEN=${2}
            shift 2
            ;;
        --download)
            DOWNLOAD=${2}
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            echo ""
            echo "Error in given Parameters. Undefined: "
            echo $*
            echo ""
            dpf_usage
            exit 1
      esac
    done
    
    echo "Downloading \"${GIT_PATH}\" to \"${DOWNLOAD}\" "

    # Download latest binary from Repo
    curl -s -o "${DOWNLOAD}" "https://x-access-token:${GIT_TOKEN}@raw.githubusercontent.com/${GIT_OWNER}/${GIT_REPO}/main/${GIT_PATH}"

}

# Usage: get-secret --key <key_name> --password <master_password> --out <return_variable_name>
get-secret() {
    local key_name=""
    local master_key=""
    local out_var=""

    # 1. Execute getopt to parse the arguments
    # -o defines short options (k:, p:, o: mean they require arguments)
    # --long defines long options
    # -n sets the name of the program reporting errors
    local parsed_args
    parsed_args=$(getopt -o k:p:o: --long key:,password:,out: -n 'get-secret' -- "$@")

    # Check if getopt threw an error (e.g., missing an argument or unknown option)
    if [[ $? -ne 0 ]]; then
        echo "Usage: get-secret --key <key> --password <pass> --out <var>" >&2
        return 1
    fi

    # 2. Overwrite the positional parameters ($1, $2, etc.) with the parsed output
    eval set -- "$parsed_args"

    # 3. Loop through the parameters
    while true; do
        case "$1" in
            -k|--key)
                key_name="$2"
                shift 2 # Shift past the flag and its argument
                ;;
            -p|--password)
                master_key="$2"
                shift 2
                ;;
            -o|--out)
                out_var="$2"
                shift 2
                ;;
            --)
                # End of options marker generated by getopt
                shift
                break
                ;;
            *)
                echo "Internal parsing error." >&2
                return 1
                ;;
        esac
    done

    # 4. Validate that all required arguments were provided
    if [[ -z "$key_name" || -z "$master_key" || -z "$out_var" ]]; then
        echo "Error: Missing required arguments." >&2
        echo "Usage: get_secret --key <key> --password <pass> --out <var>" >&2
        return 1
    fi

    # 5. Setup the name reference for the return variable
    local -n _return_var="$out_var"

    # 6. Retrieve and decrypt the secret
    local encrypted_value="${EncryptedKeys[$key_name]}"

    if [[ -z "$encrypted_value" ]]; then
        echo "Error: Secret '$key_name' not found in the array." >&2
        return 1
    fi

    local decrypted
    decrypted=$(echo "$encrypted_value" | openssl enc -aes-256-cbc -a -d -salt -pbkdf2 -pass "pass:$master_key" 2>/dev/null)

    if [[ $? -ne 0 ]]; then
        echo "Error: Decryption failed for '$key_name'. Wrong password?" >&2
        return 1
    fi

    # 7. Assign the decrypted string directly to the reference variable
    _return_var="$decrypted"
    return 0 # Return success code
}

# Will add line to config if value does not exist, if it does exist then it updates the value
# Usage: update-config --file <file_path> --key <config_key> --value <value>
update-config () {
    local FILE=""
    local KEY=""
    local VALUE=""

    local parsed_args
    parsed_args=$(getopt -o f:k:v: --long file:,key:,value: -n 'update-config' -- "$@")

    # Check if getopt threw an error (e.g., missing an argument or unknown option)
    if [[ $? -ne 0 ]]; then
        echo "Usage: update-config --file <file_path> --key <config_key> --value <value>" >&2
        return 1
    fi

    # overwrite the positional parameters ($1, $2, etc.) with the parsed output
    eval set -- "$parsed_args"

    Loop through the parameters
    while true; do
        case "$1" in
            -f|--file)
                FILE="$2"
                shift 2 # Shift past the flag and its argument
                ;;
            -k|--key)
                KEY="$2"
                shift 2
                ;;
            -v|--value)
                VALUE="$2"
                shift 2
                ;;
            --)
                # End of options marker generated by getopt
                shift
                break
                ;;
            *)
                echo "Internal parsing error." >&2
                return 1
                ;;
        esac
    done

    Validate that all required arguments were provided
    if [[ -z "${FILE}" || -z "${KEY}" || -z "${VALUE}" ]]; then
        echo "Error: Missing required arguments." >&2
        echo "Usage: update-config --file <file_path> --key <config_key> --value <value>" >&2
        return 1
    fi

    if grep -q "^${KEY}" "${FILE}"; then
        sed -i "s/^${KEY}.*/${KEY}${VALUE}/" "${FILE}"
    else
        echo "${KEY}${VALUE}" >> "${FILE}"
    fi
}

